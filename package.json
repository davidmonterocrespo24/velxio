{
  "name": "velxio-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/master",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "build:sdk": "npm --workspace=@velxio/sdk run build",
    "test:sdk": "npm --workspace=@velxio/sdk run test",
    "smoke:sdk": "node packages/sdk/scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
