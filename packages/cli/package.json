{
  "name": "@velxio/cli",
  "version": "0.1.0",
  "description": "Author CLI for building, validating and packaging Velxio plugins.",
  "license": "MIT",
  "author": "David Montero <davidmonterocrespo24@gmail.com>",
  "homepage": "https://velxio.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmonterocrespo24/velxio.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/davidmonterocrespo24/velxio/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "velxio-plugin": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@velxio/sdk": "0.1.0",
    "commander": "^12.1.0",
    "esbuild": "^0.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.11.0",
    "eslint": "^9.39.1",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.0.18",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "velxio",
    "cli",
    "plugin",
    "arduino",
    "simulator",
    "wokwi"
  ]
}
